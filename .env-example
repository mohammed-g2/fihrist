# Flask config
FLASK_APP=run:app
#FLASK_DEBUG=
#FLASK_ENV=

# App config
SECRET_KEY=""
# one of: development, testing, production
# production setting disables migration
# testing default to in memory database
ENV=""
# email added here will have administrator permissions when
# creating a new account
ADMIN_EMAIL=""
# do not set this manually, use `flask test --coverage`
# test coverage reports at tmp/coverage/
COVERAGE=""

# Mail config
#127.0.0.1 or 0.0.0.0
MAIL_SERVER=""
#1025
MAIL_PORT=""
# LTS on ['true', 'on', 1]
MAIL_USE_TLS=""
MAIL_USERNAME=""
MAIL_PASSWORD=""

# Database config
DEV_DATABASE_URL=""
TEST_DATABASE_URL=""
DATABASE_URL=""
